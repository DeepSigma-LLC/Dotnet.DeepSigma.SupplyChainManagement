<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Version>1.0.0</Version>
    <Authors>DeepSigma LLC</Authors>
    <Description>A library containing Supply Chain Management utilities.</Description>
    <PackageProjectUrl>https://github.com/DeepSigma-LLC/Dotnet.DeepSigma.SupplyChainManagement</PackageProjectUrl>
    <PackageIcon>Assets\DeepSigma.png</PackageIcon>
    <Title>DeepSigma.SupplyChainManagement</Title>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\DeepSigma.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DeepSigma.General" Version="3.0.0" />
    <PackageReference Include="DeepSigma.Mathematics" Version="1.4.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\DeepSigma.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
